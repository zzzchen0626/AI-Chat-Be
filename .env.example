NODE_ENV=development
PORT=3000

# Local MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=password
DB_DATABASE=ai_chat

# Production PostgreSQL / Supabase
# Set this in production environments such as Render.
# When DATABASE_URL is present, the app uses PostgreSQL with SSL.
DATABASE_URL=postgresql://user:password@host:5432/database

# CORS
CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Redis
redis_server_host=localhost
redis_server_port=6379
redis_server_db=1

# JWT
JWT_SECRET=replace_me

# AI providers
DASHSCOPE_API_KEY=replace_me
OPENAI_API_KEY=replace_me

# Nodemailer
nodemailer_host=smtp.qq.com
nodemailer_port=587
nodemailer_auth_user=replace_me@example.com
nodemailer_auth_pass=replace_me
nodemailer_from_address=replace_me@example.com
nodemailer_from_name=AI Chat
